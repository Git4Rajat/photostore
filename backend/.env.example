# Backend configuration example.
# Copy to `.env` (gitignored) for local development, or set these as
# environment variables / Container App settings in production.
#
# Only the essentials are listed here. Many more optional knobs exist
# (face clustering, geocoding, tag limits, etc.) with sensible defaults —
# search the code for os.environ.get / os.getenv to see them all.

# ---------------------------------------------------------------------------
# Storage (required)
# ---------------------------------------------------------------------------
# Storage account name used with managed identity (DefaultAzureCredential).
# Preferred for production (no secrets in config).
AZURE_STORAGE_ACCOUNT_NAME=

# Alternatively, a full connection string for local dev / non-managed-identity
# setups (e.g. the Azurite emulator). Leave blank if using the account name above.
AZURE_STORAGE_CONNECTION_STRING=

# Blob containers and tables (defaults shown; usually no need to change).
BLOB_IMAGE_CONTAINER=images
BLOB_THUMBNAIL_CONTAINER=thumbnails
BLOB_COVER_CONTAINER=covers
METADATA_TABLE=photometadata
ALBUMS_TABLE=photoalbums

# ---------------------------------------------------------------------------
# CORS / origins (required)
# ---------------------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Allow any localhost origin during development.
ALLOW_LOCALHOST_ORIGINS=true

# ---------------------------------------------------------------------------
# Auth (Microsoft Entra ID only)
# ---------------------------------------------------------------------------
# Require authentication for API access. Set false only for local dev.
AUTH_REQUIRED=true
AUTH_MODE=entra

# Microsoft Entra ID (Azure AD). Create your OWN app registrations in your
# tenant and paste the IDs here. Required when AUTH_REQUIRED=true.
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_API_AUDIENCE=

# Secret used to sign public album share grants. Generate a strong random value.
ALBUM_GRANT_SECRET=

# ---------------------------------------------------------------------------
# App behavior (optional)
# ---------------------------------------------------------------------------
# Public base URL of the frontend, used to compose shareable album links.
SPA_BASE_URL=
LOG_LEVEL=INFO
MAX_UPLOAD_FILE_BYTES=268435456
