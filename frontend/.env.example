# ---------------------------------------------------------------------------
# API endpoints
# ---------------------------------------------------------------------------
# In production these point at your deployed Azure Container App backend, e.g.
#   REACT_APP_API_BASE_URL=https://<appName>-backend.<region>.azurecontainerapps.io
# This project also supports runtime config via env.js injected at deploy time,
# which overrides these build-time values.
REACT_APP_API_BASE_URL=http://localhost:5001
REACT_APP_UPLOAD_BASE_URL=http://localhost:5001

# ---------------------------------------------------------------------------
# Auth mode
# ---------------------------------------------------------------------------
# 'password' = single-owner email + password (the simple self-host default).
#              No further settings are needed here — the sign-in form talks to
#              the backend /auth/* endpoints.
# 'entra'    = Microsoft Entra SSO (advanced; see deploy/setup-auth.sh).
REACT_APP_AUTH_MODE=password

# --- Entra mode (REACT_APP_AUTH_MODE=entra) ---
# Paste your frontend SPA app registration's IDs. Ignored in password mode.
REACT_APP_AZURE_AD_CLIENT_ID=<YOUR_AZURE_AD_APP_CLIENT_ID>
REACT_APP_AZURE_AD_TENANT_ID=<YOUR_AZURE_AD_TENANT_ID>
# API scope exposed by the backend app registration (defaults to
# api://<clientId>/access_as_user when omitted).
REACT_APP_AZURE_AD_API_SCOPE=<YOUR_AZURE_AD_API_SCOPE>
REACT_APP_AZURE_AD_AUTHORITY=https://login.microsoftonline.com/common
