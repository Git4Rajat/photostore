# In production, set this to your deployed Azure Container App endpoint. Example:
# REACT_APP_API_BASE_URL=https://func-file-storage-backend-abc123.azurewebsites.net/api
# This project also supports runtime config via env.js injected during deployment.
REACT_APP_API_BASE_URL=http://localhost:5001
REACT_APP_UPLOAD_BASE_URL=http://localhost:5001
# Microsoft Entra ID (Azure AD) sign-in. Paste your SPA app registration's IDs.
REACT_APP_AZURE_AD_CLIENT_ID=<YOUR_AZURE_AD_APP_CLIENT_ID>
REACT_APP_AZURE_AD_TENANT_ID=<YOUR_AZURE_AD_TENANT_ID>
REACT_APP_AZURE_AD_AUTHORITY=https://login.microsoftonline.com/common
REACT_APP_AUTH_MODE=entra
